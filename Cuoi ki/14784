class Animal():
    def __init__(self, name: str, atk: int, hp: int, defense: int, role: str):
        self.name = name
        self.atk = atk
        self.hp = hp
        self.defense = defense
        self.role = role
        self.state = "Alive"    
        
    @property
    def state(self):
        return self._state
    
    @state.setter
    def state(self, state):
        if state == "Alive" or state == "Dead":
            self._state = state 

    def __str__(self):
        return f"{self.role} {self.name}: {int(self.hp)}"
    
    def attack(self, animal: "Animal"):
        # Write your code here
        if self.hp<=0:
            self.hp=0
            print(f"{self.name} is already dead")
            return
        if animal.hp<=0:
            animal.hp=0
            print(f"{animal.name} is already dead")
            return
        if self.role=='Warrior':
            damage=int(max(0,self.atk-animal.defense*0.75))
            if animal.role=='Tank':
                animal.hp=animal.hp-int(damage*0.5)
            else:
                animal.hp=animal.hp-damage
        elif self.role=="Mage":
            damage=int(max(self.atk+animal.atk*0.8-animal.defense,0))
            if animal.role=='Tank':
                animal.hp=animal.hp-int(damage*0.5)
            else:
                animal.hp=animal.hp-damage
        else:
            damage=int(max(0,self.atk-animal.defense))
            if animal.role=='Tank':
                animal.hp=animal.hp-int(damage*0.5)
            else:
                animal.hp=animal.hp-damage
        if animal.hp<=0:
            animal.hp=0
            animal.state='Dead'
            
        
    
