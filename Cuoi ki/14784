line_one = input().split()
animals=[]
for i in range(int(line_one[1])):
    character=input().split()
    
    name=character[0]
    atk=int(character[1])
    hp=int(character[2])
    defense=int(character[3])
    role=character[4]
    animal=Animal(name,atk,hp,defense,role)
    animals.append(animal)

for i in range(int(line_one[0])):
    brawl=input().split()
    attacker_name=brawl[0]
    defender_name=brawl[1]

    attacker=next(a for a in animals if a.name==attacker_name)
    defender=next(a for a in animals if a.name==defender_name)
    
    attacker.attack(defender)
for i in animals:
    if i.state=='Alive':
        print(i)   
