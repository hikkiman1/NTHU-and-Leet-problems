rows,cols,time=map(int,input().split())
time=time%4
pic=[]
for i in range(rows):
    pic.append(list(map(int,input().split())))

def rotate2(board):
    board=[list(row) for row in zip(*board)]
    for i in board:
        i.reverse()
    return board
for i in range(time):
    pic=rotate2(pic)
for i in pic:
    print(' '.join(str(j) for j in i))