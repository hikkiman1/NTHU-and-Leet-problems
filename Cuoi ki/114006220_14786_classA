rows,cols,time=map(int,input().split())
time=time%4
pic=[]
for i in range(rows):
    pic.append(list(map(int,input().split())))


def rotate(board,row,col,cases):
    test=[]
    for i in range(col):
        hang=[]
        for j in range(row):
            hang.append(board[j][i])
        hang.reverse()
        test.append(hang)
    for i in range(cases-1):
        test=rotate(test,col,row,cases-2)
    return test
rotated_pic=rotate(pic,rows,cols,time)
for row in rotated_pic:
    print(' '.join(str(item) for item in row))
