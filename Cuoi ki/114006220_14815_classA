def double_gen(nums):
    """Yield each number doubled."""
    # TODO
    for i in nums:
        yield i*2

def square_gen(nums):
    """Yield each number squared."""
    # TODO
    for i in nums:
        yield i**2

def odd_gen(nums):
    """Yield only odd numbers."""
    # TODO
    for i in nums:
        if i % 2==1:
            yield i

def even_gen(nums):
    """Yield only even numbers."""
    # TODO
    for i in nums:
        if i % 2 ==0:
            yield i

def compose_generators(gens, start_stream):
    """Chain all generators together in order."""
    # TODO: apply each generator in sequence to the stream
    stream=start_stream
    for g in gens:
        stream=g(stream)
    return stream   

