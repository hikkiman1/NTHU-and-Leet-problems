class Character:
    def __init__(self, name, hp, attack, defense):
        self.name = name
        self.hp = hp
        self.attack = attack
        self.defense = defense
        self.buff_func = lambda atk, dfs, hp: (atk, dfs, hp)  # identity function

    def apply_buffs(self):
        """
        #TODO: 
        Apply the composed buff function to (attack, defense, hp).
        Returns the updated (attack, defense, hp).
        """
        self.attack,self.defense,self.hp=self.buff_func(self.attack,self.defense,self.hp)
        return self.attack,self.defense,self.hp
  
    def is_alive(self):
        #TODO: Return True if HP > 0.
        return self.hp>0
  
    def take_damage(self, amount):
        #TODO: Reduce HP by damage
        self.hp-=amount
  
    def attack_target(self, other):
        #TODO: Attack another character
        damage=max(1,self.attack-other.defense)
        other.take_damage(damage)
        return damage
  
def compose_buffs(*funcs):
    """Compose multiple buffs into one function."""
    def compose(atk,dfs,hp):
        for f in funcs:
            atk,dfs,hp=f(atk,dfs,hp)
        return atk,dfs,hp
    return compose
  
def buff_factory(cmd, x):
    """Return a buff function that modifies (atk, dfs, hp)."""
    if cmd == "atk_add":
        return lambda atk,dfs,hp: (atk+x,dfs,hp)
    elif cmd == "atk_mul":
        return lambda atk,dfs,hp: (atk*x,dfs,hp)
    elif cmd == "dfs_add":
        return lambda atk,dfs,hp: (atk,dfs+x,hp)
    elif cmd == "dfs_mul":
        return lambda atk,dfs,hp: (atk,dfs*x,hp)
    else:
        return lambda atk,dfs,hp: (atk,dfs,hp)
  
def battle(c1, c2):
    """
    #TODO
    Turn-based battle: c1 attacks first, alternate until one dies.
    returns the winner's name and hp
    """
    
    attacker=c1
    defender=c2
    while c1.is_alive() and c2.is_alive():
        attacker.apply_buffs() 
        defender.apply_buffs()
        
        attacker.attack_target(defender)

        
        attacker,defender=defender,attacker
    if c1.is_alive():
        winner=c1
    else:
        winner=c2
    return winner.name, winner.hp
  
if __name__ == "__main__":
    # Input format:
    # name1 hp1 atk1 dfs1
    # name2 hp2 atk2 dfs2
    # n
    # Then n lines:
    # target cmd value
    # (target is either name1 or name2)
    n1, h1, a1, d1 = input().split()
    n2, h2, a2, d2 = input().split()
    c1 = Character(n1, int(h1), int(a1), int(d1))
    c2 = Character(n2, int(h2), int(a2), int(d2))
  
    n = int(input())
    buffs_c1 = []
    buffs_c2 = []
    for _ in range(n):
        target, cmd, val = input().split()
        buff = buff_factory(cmd, float(val))
        if target == c1.name:
            buffs_c1.append(buff)
        elif target == c2.name:
            buffs_c2.append(buff)
  
    c1.buff_func = compose_buffs(*buffs_c1)
    c2.buff_func = compose_buffs(*buffs_c2)
  
    winner, hp_left = battle(c1, c2)
    print(f"{winner} wins with {hp_left:.1f} HP left.")
